# Variables de Entorno para Citas Médicas
#
# En Railway, el servicio MySQL inyecta automáticamente las siguientes variables:
#   MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT
# config.php las lee directamente, por lo que no es necesario definirlas aquí
# en producción. Este archivo es únicamente para desarrollo local.

# ── Desarrollo local ──────────────────────────────────────────────────────────
# Descomenta y ajusta estos valores para tu entorno local. En Railway estas
# variables son provistas por el servicio MySQL y no deben sobreescribirse.
#
# MYSQLHOST=127.0.0.1
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=root123
# MYSQLDATABASE=citas_medicas

# Aplicación
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# MySQL (usado por docker-compose para inicializar el contenedor local)
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=citas_medicas
MYSQL_USER=citas_user
MYSQL_PASSWORD=citas123
